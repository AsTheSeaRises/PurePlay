{
  "manifest_version": 3,
  "name": "PurePlay — Block AI Artists on Spotify",
  "version": "1.0.0",
  "description": "Automatically blocks AI-generated artists on Spotify using community lists and smart heuristics.",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://open.spotify.com/*",
    "https://spclient.wg.spotify.com/*",
    "https://api.spotify.com/*",
    "https://raw.githubusercontent.com/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://open.spotify.com/*"],
      "js": ["src/content/inject.ts"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://open.spotify.com/*"],
      "js": ["src/content/token-interceptor.ts"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "commands": {
    "report-current-artist": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Report the currently playing Spotify artist as AI-generated"
    }
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "src/assets/icon-16.png",
      "48": "src/assets/icon-48.png",
      "128": "src/assets/icon-128.png"
    }
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "src/assets/icon-16.png",
    "48": "src/assets/icon-48.png",
    "128": "src/assets/icon-128.png"
  }
}
